# ─────────────────────────────────────────────────────────────────────────────
# AGRIOS Frontend — Environment Configuration (Vercel / local)
# Copy to frontend/.env for local dev; in production set these in the Vercel
# project. Only variables prefixed VITE_ are exposed to the client bundle at
# BUILD time — they are baked into the build and are therefore PUBLIC (never put
# a secret here). Every VITE_ var below is read in frontend/src.
# ─────────────────────────────────────────────────────────────────────────────

# REQUIRED — full backend base URL INCLUDING the /api/v1 suffix.
# Local dev may omit this; the app falls back to "/api/v1" (proxied to :8000).
# Production: https://api.greena.app/api/v1
#
# MUST AGREE WITH THE CSP. vercel.json's Content-Security-Policy lists the API
# origin in connect-src; a browser blocks every request to an origin missing
# from that list, so pointing this at a host the CSP does not name breaks the
# entire app with nothing but console errors to show for it. Change both, or
# neither.
VITE_API_BASE_URL=http://localhost:8000/api/v1

# OPTIONAL — app environment tag (feeds Sentry environment + dev checks).
# development | staging | production
VITE_ENVIRONMENT=development

# OPTIONAL — frontend Sentry DSN (separate project from the backend). Leave blank
# in development; error monitoring is disabled when empty.
VITE_SENTRY_DSN=
