# AGRIOS Frontend — Environment Variables
# Copy to .env and .env.production

# API base URL
VITE_API_BASE_URL=http://localhost:8000/api/v1
# Production: https://api.agrios.app/api/v1

# App environment
VITE_ENVIRONMENT=development
# Options: development | staging | production

# Sentry (leave empty in development)
VITE_SENTRY_DSN=
