{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "greena-web",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--", "--host", "127.0.0.1"],
      "cwd": "frontend",
      "port": 5173,
      "autoPort": true
    },
    {
      "name": "greena-api",
      "runtimeExecutable": ".venv/Scripts/python.exe",
      "runtimeArgs": ["-m", "uvicorn", "app.main:app", "--reload", "--port", "8000"],
      "cwd": "backend",
      "port": 8000
    },
    {
      "name": "brand-static",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "http.server", "5599", "--directory", "brand"],
      "port": 5599
    }
  ]
}
