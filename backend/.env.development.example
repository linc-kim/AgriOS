# AGRIOS — Development environment template.
# Copy to backend/.env for local dev, then fill in real secrets.
# The app (app/config.py) reads backend/.env only; this file is documentation.

# Native Postgres (this machine) OR Docker `db` service — both expose port 5432.
# Note: the username must NOT contain the substring used to derive the test DB.
# We use the `postgres` superuser locally so tests resolve to .../agrios_test cleanly.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/agrios

# Generate each (must differ):  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_token_hex_32
JWT_SECRET=CHANGE_ME_distinct_token_hex_32

ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
TZ=Africa/Nairobi

JWT_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
OTP_EXPIRE_MINUTES=10
OTP_MAX_ATTEMPTS=3
OTP_MAX_REQUESTS_PER_PHONE=3
OTP_REQUEST_WINDOW_MINUTES=10
