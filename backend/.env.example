# ─────────────────────────────────────────────────────────────────────────────
# AGRIOS Backend — Environment Configuration (Railway / local)
# Copy to backend/.env for local dev. In production set these in the Railway
# service. Every variable below is read by backend/app/config.py (pydantic
# Settings); nothing else is consumed at runtime.
# NEVER commit a real .env.
# ─────────────────────────────────────────────────────────────────────────────

# ══ REQUIRED — the app will not start without these ═════════════════════════════

# Full Postgres connection string. Any scheme is accepted; config.py rewrites it
# to postgresql+asyncpg:// automatically.
# Supabase: use the SESSION POOLER string (Project Settings → Database →
# Connection string → Session pooler). It is IPv4 and supports prepared
# statements. Keep the pooler username form "postgres.<project-ref>".
#   postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql+asyncpg://agrios:agrios_dev@localhost:5432/agrios

# General signing secret (64 hex chars). Generate:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_generate_with_secrets_token_hex_32

# JWT signing secret — MUST differ from SECRET_KEY. Generate:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_ME_distinct_from_SECRET_KEY

# ══ APPLICATION ═════════════════════════════════════════════════════════════════

# development | staging | production  — gates security headers, Sentry, and /docs.
ENVIRONMENT=development

# CORS allow-list, comma-separated, NO spaces. Must include the live frontend
# origin(s) in production (e.g. https://app.agrios.app,https://admin.agrios.app).
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Scheduler + timestamp timezone. Do not change — cron jobs assume it.
TZ=Africa/Nairobi

# ══ AUTHENTICATION (defaults are the frozen Engineering-Constitution values) ════
JWT_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
OTP_EXPIRE_MINUTES=10
OTP_MAX_ATTEMPTS=3
OTP_MAX_REQUESTS_PER_PHONE=3
OTP_REQUEST_WINDOW_MINUTES=10

# ══ SMS — Africa's Talking (OPTIONAL; dormant until all four are set) ═══════════
# Leave blank at launch. SMS OTP/notifications activate by configuration alone
# once these exist (the africastalking package is already installed). Set
# AT_ENVIRONMENT=production for real delivery.
AT_API_KEY=
AT_USERNAME=
AT_SENDER_ID=AGRIOS
AT_ENVIRONMENT=sandbox

# ══ AI PROVIDERS (OPTIONAL; ARIA degrades gracefully if absent) ════════════════
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5-20251001

# AI budget guards (frozen defaults).
AI_CONTEXT_MAX_TOKENS=8000
AI_CALL_TIMEOUT_SECONDS=15
AI_RESPONSE_MAX_WORDS=150

# ══ MONITORING (OPTIONAL) ═══════════════════════════════════════════════════════
# Backend Sentry DSN. Leave blank in development.
SENTRY_DSN=

# ── NOTE: Email OTP is Phase 2 and not yet implemented in code. EMAIL_* variables
#    referenced in DEPLOYMENT_GUIDE.md are NOT consumed by config.py today; do not
#    expect email delivery until that work lands.
