# ─────────────────────────────────────────────
# AGRIOS Backend — Environment Configuration
# Copy to .env and fill in values before running
# NEVER commit .env to version control
# ─────────────────────────────────────────────

# ── Application ──────────────────────────────
ENVIRONMENT=development
# Options: development | staging | production

SECRET_KEY=CHANGE_ME_32_CHAR_RANDOM_STRING_HERE
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"

ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
# Production: https://app.agrios.app,https://admin.agrios.app

# ── Database ─────────────────────────────────
DATABASE_URL=postgresql+asyncpg://agrios:agrios_dev@localhost:5432/agrios
# Supabase production format:
# postgresql+asyncpg://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres

# ── Authentication ───────────────────────────
JWT_SECRET=CHANGE_ME_64_CHAR_RANDOM_STRING_HERE
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"

JWT_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Africa's Talking (SMS) ───────────────────
AT_API_KEY=your_africas_talking_api_key
AT_USERNAME=your_africas_talking_username
AT_SENDER_ID=AGRIOS
AT_ENVIRONMENT=sandbox
# Options: sandbox | production

# ── AI Providers ─────────────────────────────
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash

CLAUDE_API_KEY=your_anthropic_api_key
CLAUDE_MODEL=claude-haiku-4-5-20251001

# ── Monitoring ───────────────────────────────
SENTRY_DSN=
# Leave empty in development

# ── Timezone ─────────────────────────────────
TZ=Africa/Nairobi
