# ─────────────────────────────────────────────────────────────────────────────
# Greena Backend — Environment Configuration (Railway / local)
#
# Copy to backend/.env for local dev. In production set these in the Railway
# service. Every variable below is read by backend/app/config.py (pydantic
# Settings) — this file is the complete list; nothing else is consumed.
# NEVER commit a real .env.
#
# Anything marked PRODUCTION-CRITICAL is checked at startup: in production the
# app raises and exits rather than serving traffic with an unsafe value.
# ─────────────────────────────────────────────────────────────────────────────

# ══ REQUIRED — the app will not start without these ═════════════════════════════

# Full Postgres connection string. Any scheme is accepted; config.py rewrites it
# to postgresql+asyncpg:// automatically.
#
# Supabase: use the SESSION POOLER string (Project Settings → Database →
# Connection string → Session pooler), port 5432. It is IPv4 and supports
# prepared statements. Keep the pooler username form "postgres.<project-ref>".
#   postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
#
# Do NOT use the TRANSACTION pooler (port 6543): it does not support the
# prepared statements asyncpg issues, and queries fail at runtime rather than
# at startup. If you must use it, asyncpg needs statement_cache_size=0.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/greena

# PRODUCTION-CRITICAL. General signing secret, 64 hex chars. Generate:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Startup refuses a value under 32 chars, one equal to JWT_SECRET, or one that
# looks like a placeholder ("changeme…", "secret…", "test…").
SECRET_KEY=CHANGE_ME_generate_with_secrets_token_hex_32

# PRODUCTION-CRITICAL. JWT signing secret — MUST differ from SECRET_KEY.
#   python -c "import secrets; print(secrets.token_hex(32))"
# Rotating this invalidates every issued access token (users re-authenticate).
JWT_SECRET=CHANGE_ME_distinct_from_SECRET_KEY

# ══ APPLICATION ═════════════════════════════════════════════════════════════════

# development | staging | production
# Gates security headers (HSTS), Sentry, /docs, secure cookies, and startup
# validation strictness.
ENVIRONMENT=development

# PRODUCTION-CRITICAL. CORS allow-list, comma-separated, NO spaces. Must include
# the live frontend origin(s), e.g. https://app.greena.app
#
# Startup refuses a wildcard or a plaintext http:// origin — the API is called
# with credentials, and either would expose authenticated requests to any site.
#
# The frontend and API must share a registrable domain (app.greena.app +
# api.greena.app). The refresh cookie is SameSite=Strict, which a browser will
# not send across sites — and vercel.app/railway.app are each on the Public
# Suffix List, so platform default hostnames count as cross-site and would
# silently break token refresh, logging every user out when their 15-minute
# access token expires.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Public URL of the frontend. Used to build links in emails (verification,
# password reset) and OAuth redirects. MUST be set in production — the default
# below would send users a link to their own machine.
FRONTEND_URL=http://localhost:5173

# Scheduler + timestamp timezone. Do not change — cron jobs assume it.
TZ=Africa/Nairobi

# Rarely changed. API route prefix, display name, and the version reported by
# /health and /production/version.
API_V1_PREFIX=/api/v1
PROJECT_NAME=Greena
VERSION=1.0.0

# ══ DATABASE POOL ═══════════════════════════════════════════════════════════════
# Per worker process. The ceiling on the database is
#   (DB_POOL_SIZE + DB_MAX_OVERFLOW) × workers  + 1 for the scheduler lock
# The Dockerfile runs 2 workers, so the defaults use at most 31 connections.
# Size these against the provider's cap: Supabase's free tier allows 60 in
# total, shared with migrations, psql sessions and any admin tooling.
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
# Recycle below the provider's idle timeout so a dead connection is never
# handed to a request.
DB_POOL_RECYCLE_SECONDS=1800

# Force TLS on the database connection for any non-local host. Supabase's
# pooler ACCEPTS plaintext, so leaving this off means the password and every
# row cross the public internet unencrypted.
DATABASE_SSL=true
# Path to the provider's CA bundle. Supabase presents a self-signed chain that
# public roots cannot verify, so without this the connection is encrypted but
# not authenticated against an active man-in-the-middle. Download from
# Project Settings → Database → SSL Configuration and mount it in the container.
DATABASE_SSL_CA=

# ══ AUTHENTICATION (defaults are the frozen Engineering-Constitution values) ════
JWT_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
OTP_EXPIRE_MINUTES=10
OTP_MAX_ATTEMPTS=3
OTP_MAX_REQUESTS_PER_PHONE=3
OTP_REQUEST_WINDOW_MINUTES=10

# Minimum account password length (Argon2id is the hasher; no 72-byte cap).
PASSWORD_MIN_LENGTH=12

# Lifetimes for the email-token flows below.
EMAIL_VERIFY_TOKEN_HOURS=24
PASSWORD_RESET_TOKEN_HOURS=1

# ══ AUTH FEATURE GATES ══════════════════════════════════════════════════════════
# All ship OFF so signup/login/onboarding work with no SMTP/SMS/OAuth
# configured. Turn each on only once its provider credentials are set below —
# enabling a flag without them will fail the corresponding flow at runtime.
REQUIRE_EMAIL_VERIFICATION=false
ENABLE_GOOGLE_OAUTH=false
ENABLE_SMS_OTP=false
ENABLE_LOGIN_ALERTS=false

# ══ EMAIL ═══════════════════════════════════════════════════════════════════════
# console = log the message instead of sending (development default — signup,
#           verification and password reset all work with no mail account).
# smtp    = send over SMTP using the SMTP_* settings below. Use this for Gmail.
EMAIL_PROVIDER=console
EMAIL_FROM=Greena <no-reply@greena.app>

# Generic SMTP. Defaults target Gmail.
#
# Gmail requires an APP PASSWORD — the account password will not authenticate,
# and 2-Step Verification must be enabled to create one:
#   Google Account → Security → 2-Step Verification → App passwords
# SMTP_USER is the full Gmail address that the App Password belongs to. Gmail
# rewrites the From address to this account unless it is a verified alias, so
# EMAIL_FROM's display name is kept but its address is replaced by SMTP_USER.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
# STARTTLS on port 587. Set false only for port 465 (implicit TLS).
SMTP_STARTTLS=true
SMTP_TIMEOUT_SECONDS=20

# Legacy Zoho fields, retained so an existing configuration keeps working.
ZOHO_SMTP_HOST=smtp.zoho.com
ZOHO_SMTP_PORT=587
ZOHO_SMTP_USER=
ZOHO_SMTP_PASSWORD=

# ══ GOOGLE OAUTH (only read when ENABLE_GOOGLE_OAUTH=true) ══════════════════════
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ══ SMS — Africa's Talking (OPTIONAL; dormant until set) ════════════════════════
# Leave blank at launch. SMS OTP/notifications activate by configuration alone
# (the africastalking package is already installed).
# NOTE: scheduled jobs send SMS. Confirm the scheduler advisory lock is working
# before enabling, or every farmer is messaged once per worker process.
AT_API_KEY=
AT_USERNAME=
AT_SENDER_ID=Greena
# NOTE: not currently read by application code (the AT SDK is initialised with
# username + api_key only). Kept for forward-compatibility.
AT_ENVIRONMENT=sandbox

# ══ AI PROVIDERS (OPTIONAL; ARIA degrades to its offline model if absent) ═══════
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5-20251001

# AI budget guards (frozen defaults).
AI_CONTEXT_MAX_TOKENS=8000
AI_CALL_TIMEOUT_SECONDS=15
AI_RESPONSE_MAX_WORDS=150

# ══ MONITORING (OPTIONAL, strongly recommended in production) ═══════════════════
# Backend Sentry DSN. Leave blank in development. Unset in production logs a
# startup warning but does not block boot — error tracking is observability,
# not a serving dependency.
SENTRY_DSN=
