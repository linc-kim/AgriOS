# AGRIOS — Test environment template.
# The test harness (tests/conftest.py) honors TEST_DATABASE_URL when set,
# otherwise it derives the URL from DATABASE_URL by swapping the database name.
# scripts/dev/verify.ps1 sets TEST_DATABASE_URL explicitly to avoid ambiguity.

# Separate database on the same cluster (native) — dropped/recreated per run.
TEST_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/agrios_test

# Docker alternative (infrastructure/docker-compose.yml `db_test` service):
# TEST_DATABASE_URL=postgresql+asyncpg://agrios:agrios_dev@localhost:5433/agrios_test
